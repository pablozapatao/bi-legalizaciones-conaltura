# ==========================================
# .gitignore — NUNCA subir secretos ni temporales
# ==========================================

# Variables de entorno (CRÍTICO: nunca en GitHub)
.env
.env.local
.env*.local
*.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*

# Logs locales
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
